{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@meli/source"],
    "baseUrl": ".",
    "paths": {
      "@meli/api": ["libs/api/src/index.ts"],
      "@meli/hooks": ["libs/hooks/src/index.ts"],
      "@meli/ui": ["libs/ui/src/index.ts"],
      "@meli/utils": ["libs/utils/src/index.ts"]
    }
  }
}
